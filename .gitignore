# Node / npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*
.envrc
!.env.example

# API keys and secrets — NEVER commit these
.ppq_key.txt
.ppq_key_b64.txt
.test_js_b64.txt
*.key
*.pem
*.enc

# Database files (contain player data / economy state)
*.db
*.db-wal
*.db-shm

# Logs
*.log
logs/

# Build / dist artifacts
dist/
build/

# System / OS files
.DS_Store
Thumbs.db

# Debian packages — never commit .deb files
*.deb

# Python cache
__pycache__/
*.pyc
*.pyo

# Shared libraries — never commit .so files
*.so
*.so.*

# IDE
.idea/
.vscode/
*.swp
*.swo

# Uploaded user content / creative assets
economy/uploads/

# Ngrok config — contains authtoken (copy ngrok.example.yml instead)
ngrok.yml

# Test seed & verification scripts (dev-only)
scripts/seed-e2e-test.js
scripts/verify-*.js

# Temp files
*.tmp
*.bak
# Service-specific env file — contains TELEGRAM_BOT_TOKEN, STRIPE keys, etc.
economy.env
