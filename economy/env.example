# Signal Rush Economy Service — Production Environment File
#
# This file is loaded by systemd (EnvironmentFile= directive).
# NEVER commit real secrets. This is a TEMPLATE.
#
# Setup:
#   1. cp economy/env.example economy.env
#   2. Edit economy.env with real values
#   3. chmod 600 economy.env
#   4. sudo cp economy/systemd/signal-rush-economy.service /etc/systemd/system/
#   5. sudo systemctl daemon-reload
#   6. sudo systemctl enable --now signal-rush-economy
#   7. sudo systemctl status signal-rush-economy
#   8. curl http://127.0.0.1:8720/health

# ─── Server ───────────────────────────────────────────────────────
ECONOMY_PORT=8720
ECONOMY_HOST=127.0.0.1
ECONOMY_DB=/home/hive/.signal-rush/economy.db
NODE_ENV=production

# ─── Auth (REQUIRED for production) ────────────────────────────────
# Leave ECONOMY_AUTH_ENFORCED on (delete the line or set to anything other than 'false').
# Generate strong random keys: openssl rand -hex 32
ECONOMY_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ADMIN_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── CORS (tunnel / production deployment) ─────────────────────────
# Comma-separated list of allowed origins for the Mini App's cross-origin calls.
# Example: https://your-tunnel.ngrok-free.dev
# Leave empty for same-origin-only (safe default).
ECONOMY_ALLOWED_ORIGINS=

# ─── Rate Limits (defensive defaults) ──────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
MAX_SPEND_PER_TX=1000

# ─── ppq.ai (player credit redemption) ────────────────────────────
# Get your API key from https://ppq.ai dashboard → Settings → API Keys
# Without this set, /credits/transfer runs in TEST MODE — claims succeed but
# no real ppq.ai credits are transferred to players.
PPQ_API_KEY=CHANGE_ME_get_from_ppq_ai_dashboard
# PPQ_API_URL=https://api.ppq.ai   # only override for testing

# ─── Stripe (advertiser deposits) ─────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
# Without these set, /portal/credits/deposit returns 500 — must install!
STRIPE_SECRET_KEY=CHANGE_ME_get_from_stripe_dashboard
# Get from https://dashboard.stripe.com/webhooks after adding endpoint
# Must be the secret shown after creating the webhook endpoint.
STRIPE_WEBHOOK_SECRET=CHANGE_ME_create_webhook_in_stripe_dashboard

# ─── Ad Economics ──────────────────────────────────────────────────
# Cost per ad impression in micros (default 1000 = $0.001).
AD_COST_MICROS_PER_IMPRESSION=1000
# Cost per house ad (no campaign) in micros (default 500).
HOUSE_AD_COST_MICROS=500