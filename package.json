{
  "name": "signal-rush-project",
  "version": "0.1.0",
  "private": true,
  "description": "Signal Rush project workspace with shared engine, CLI game, and future web/admin surfaces.",
  "scripts": {
    "cli": "node src/cli/index.js",
    "cli:demo": "node src/cli/index.js --demo",
    "cli:embed": "node src/cli/embedded.js",
    "cli:embed:demo": "node src/cli/embedded.js --demo",
    "test": "npm run test:mechanics && npm run test:smoke && npm run test:persistence && npm run test:compact && npm run test:embedded && npm run verify:frogger-render && npm run verify:ai-hunt-polish",
    "test:mechanics": "node scripts/mechanics-test.js",
    "test:smoke": "node scripts/smoke-test.js",
    "test:persistence": "node scripts/persistence-test.js && node scripts/persistence-e2e-test.js",
    "test:compact": "node scripts/compact-render-test.js",
    "test:embedded": "node scripts/embedded-test.js",
    "verify:frogger-render": "node scripts/verify-frogger-render.js",
    "verify:ai-hunt-polish": "node scripts/verify-ai-hunt-polish.js",
    "sync:github": "bash scripts/safe-sync-github.sh",
    "sync:github:fresh": "SIGNAL_RUSH_FRESH_CLONE=1 bash scripts/safe-sync-github.sh",
    "install:auto-sync": "bash scripts/install-auto-sync-hook.sh"
  },
  "engines": {
    "node": ">=18"
  }
}