# Signal Rush — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env or any file containing real secrets

# ─── Economy Service ──────────────────────────────────────────────
# Host and port for the economy HTTP API (localhost only)
ECONOMY_HOST=127.0.0.1
ECONOMY_PORT=8720

# Path to the SQLite database for the economy service
# Default: ~/.signal-rush/economy.db
ECONOMY_DB=

# ─── Authentication ────────────────────────────────────────────────
# Shared secret for internal API authentication (event bridge → economy service)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST match between the CLI event bridge and the economy service
ECONOMY_API_KEY=

# ─── Rate Limiting ─────────────────────────────────────────────────
# Max requests per window per client (IP or player)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Anti-Fraud ────────────────────────────────────────────────────
# Max credits a single session can earn before flagging for review
MAX_CREDITS_PER_SESSION=10000

# Max credits a player can spend in a single transaction
MAX_SPEND_PER_TX=1000

# ─── Payment Integration (Phase 2 — not yet implemented) ──────────
# x402 payment protocol
X402_PROVIDER_URL=
X402_API_KEY=
X402_WALLET_ADDRESS=

# Token redemption provider (e.g., OpenRouter, Nous)
TOKEN_PROVIDER_API_KEY=
TOKEN_PROVIDER_URL=
